generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Projects
// =============================================================================

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  order       Int      @default(0)
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  imageUrl    String   @default("")
  category    String   @default("")
  externalUrl String   @default("")
  tags        String   @default("[]")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  translations ProjectTranslation[]

  @@index([slug])
  @@index([category])
  @@index([featured, published])
  @@index([order])
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  locale      String
  name        String  @default("")
  tagline     String  @default("")
  description String  @default("")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale])
}

// =============================================================================
// Global Translations (UI i18n)
// =============================================================================

model Translation {
  id     String @id @default(cuid())
  key    String
  locale String
  value  String

  @@unique([key, locale])
  @@index([locale])
}

// =============================================================================
// Settings
// =============================================================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
}

// =============================================================================
// Users
// =============================================================================

enum Role {
  USER
  ADMIN
  SELLER
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String?  @unique
  phone     String?  @unique
  password  String
  role      Role     @default(USER)
  avatar    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  orders    Order[]
  adminMember AdminMember?

  @@index([email])
  @@index([phone])
}

// =============================================================================
// JOMAA STORE Marketplace
// =============================================================================

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  image    String    @default("")
  products Product[]
}

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String
  price       Decimal     @db.Decimal(12, 2)
  images      String[]    @default([])
  categoryId  String      @db.Uuid
  sellerId    String      @db.Uuid
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model Order {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid
  totalPrice Decimal     @db.Decimal(12, 2)
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// =============================================================================
// Contact
// =============================================================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String
  message   String
  locale    String   @default("en")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([phone])
}

// =============================================================================
// CMS Pages
// =============================================================================

model Page {
  id            String            @id @default(cuid())
  slug          String            @unique
  published     Boolean           @default(true)
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sections      PageSection[]
  translations  PageTranslation[]

  @@index([order])
}

model PageTranslation {
  id        String @id @default(cuid())
  pageId    String
  locale    String
  title     String @default("")
  subtitle  String @default("")
  page      Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@index([locale])
}

model PageSection {
  id            String                    @id @default(cuid())
  pageId        String
  type          String                    @default("")
  order         Int                       @default(0)
  settings      String                    @default("{}")
  page          Page                      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  translations  PageSectionTranslation[]

  @@index([pageId, order])
}

model PageSectionTranslation {
  id         String      @id @default(cuid())
  sectionId  String
  locale     String
  title      String      @default("")
  subtitle   String      @default("")
  content    String      @default("")
  buttonText String      @default("")
  section    PageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
}

// =============================================================================
// Media Library
// =============================================================================

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String   @default("")
  mimeType     String   @default("")
  size         Int      @default(0)
  url          String
  alt          String   @default("")
  category     String   @default("general")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// =============================================================================
// CIAR Super Platform
// =============================================================================

enum PlatformVisibility {
  VISIBLE
  HIDDEN
}

enum ModuleSlug {
  FASHION
  GLOBAL_PRODUCTS
  VIP
  MALL
  TOURISM
  REAL_ESTATE
  CARS
  SERVICES
  SHIPPING
  JOBS
  ADS_MARKETING
  INVESTMENT
  DELIVERY_SYSTEM
  TAXI_SYSTEM
  INTERNAL_MANAGEMENT
}

enum AdminAccessRole {
  ADMIN
  MANAGER
  EDITOR
}

model PlatformModule {
  id           String             @id @default(cuid())
  slug         ModuleSlug         @unique
  nameEn       String
  nameAr       String
  descriptionEn String            @default("")
  descriptionAr String            @default("")
  visibility   PlatformVisibility @default(VISIBLE)
  isEnabled    Boolean            @default(true)
  order        Int                @default(0)
  banner       PlatformBanner?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model PlatformBanner {
  id            String         @id @default(cuid())
  moduleId       String         @unique
  titleEn        String
  titleAr        String
  descriptionEn  String         @default("")
  descriptionAr  String         @default("")
  ctaTextEn      String         @default("Explore")
  ctaTextAr      String         @default("استكشف")
  ctaHref        String         @default("#")
  imageUrl1      String
  imageUrl2      String
  imageUrl3      String
  isActive       Boolean        @default(true)
  module         PlatformModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model AdminMember {
  id         String          @id @default(cuid())
  userId     String?         @unique @db.Uuid
  name       String
  email      String          @unique
  role       AdminAccessRole @default(EDITOR)
  isActive   Boolean         @default(true)
  user       User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model FashionItem {
  id         String   @id @default(cuid())
  title      String
  category   String
  price      Decimal  @db.Decimal(12, 2)
  imageUrl   String   @default("")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model GlobalProductItem {
  id         String   @id @default(cuid())
  title      String
  origin     String   @default("")
  marketType String   @default("B2C")
  price      Decimal  @db.Decimal(12, 2)
  imageUrl   String   @default("")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model VipProductItem {
  id          String   @id @default(cuid())
  title       String
  brand       String   @default("")
  price       Decimal  @db.Decimal(12, 2)
  imageUrl    String   @default("")
  isExclusive Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MallListing {
  id          String   @id @default(cuid())
  vendorName  String
  title       String
  price       Decimal  @db.Decimal(12, 2)
  discountPct Int      @default(0)
  imageUrl    String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TourismOffer {
  id            String   @id @default(cuid())
  agencyName    String
  destination   String
  packagePrice  Decimal  @db.Decimal(12, 2)
  durationDays  Int      @default(1)
  isBookable    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RealEstateListing {
  id            String   @id @default(cuid())
  listingType   String
  country       String
  city          String
  price         Decimal  @db.Decimal(14, 2)
  areaSqm       Int      @default(0)
  bedrooms      Int      @default(0)
  imageUrl      String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CarListing {
  id            String   @id @default(cuid())
  listingType   String
  make          String
  model         String
  year          Int
  price         Decimal  @db.Decimal(14, 2)
  city          String   @default("")
  imageUrl      String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceListing {
  id            String   @id @default(cuid())
  category      String
  providerName  String
  title         String
  price         Decimal  @db.Decimal(12, 2)
  city          String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ShippingOrder {
  id            String   @id @default(cuid())
  method        String
  sourceCountry String
  targetCountry String
  weightKg      Decimal  @db.Decimal(10, 2)
  cost          Decimal  @db.Decimal(12, 2)
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model JobListing {
  id             String   @id @default(cuid())
  title          String
  companyName    String
  city           String
  salaryRange    String   @default("")
  hasHousing     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MarketingCampaign {
  id            String   @id @default(cuid())
  campaignName  String
  budget        Decimal  @db.Decimal(14, 2)
  channel       String
  status        String   @default("DRAFT")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InvestmentShare {
  id             String   @id @default(cuid())
  investorName   String
  sharesCount    Int      @default(0)
  rewardPoints   Int      @default(0)
  totalValue     Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
