generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Projects
// =============================================================================

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  order       Int      @default(0)
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  imageUrl    String   @default("")
  category    String   @default("")
  externalUrl String   @default("")
  tags        String   @default("[]")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  translations ProjectTranslation[]

  @@index([slug])
  @@index([category])
  @@index([featured, published])
  @@index([order])
}

model ProjectTranslation {
  id          String  @id @default(cuid())
  projectId   String
  locale      String
  name        String  @default("")
  tagline     String  @default("")
  description String  @default("")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale])
}

// =============================================================================
// Global Translations (UI i18n)
// =============================================================================

model Translation {
  id     String @id @default(cuid())
  key    String
  locale String
  value  String

  @@unique([key, locale])
  @@index([locale])
}

// =============================================================================
// Settings
// =============================================================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")
}

// =============================================================================
// Users
// =============================================================================

enum Role {
  USER
  ADMIN
  SELLER
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatar    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
  orders    Order[]

  @@index([email])
}

// =============================================================================
// JOMAA STORE Marketplace
// =============================================================================

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  image    String    @default("")
  products Product[]
}

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String
  price       Decimal     @db.Decimal(12, 2)
  images      String[]    @default([])
  categoryId  String      @db.Uuid
  sellerId    String      @db.Uuid
  stock       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([sellerId])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

model Order {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid
  totalPrice Decimal     @db.Decimal(12, 2)
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// =============================================================================
// Contact
// =============================================================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  locale    String   @default("en")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

// =============================================================================
// CMS Pages
// =============================================================================

model Page {
  id            String            @id @default(cuid())
  slug          String            @unique
  published     Boolean           @default(true)
  order         Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sections      PageSection[]
  translations  PageTranslation[]

  @@index([order])
}

model PageTranslation {
  id        String @id @default(cuid())
  pageId    String
  locale    String
  title     String @default("")
  subtitle  String @default("")
  page      Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@index([locale])
}

model PageSection {
  id            String                    @id @default(cuid())
  pageId        String
  type          String                    @default("")
  order         Int                       @default(0)
  settings      String                    @default("{}")
  page          Page                      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  translations  PageSectionTranslation[]

  @@index([pageId, order])
}

model PageSectionTranslation {
  id         String      @id @default(cuid())
  sectionId  String
  locale     String
  title      String      @default("")
  subtitle   String      @default("")
  content    String      @default("")
  buttonText String      @default("")
  section    PageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
}

// =============================================================================
// Media Library
// =============================================================================

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String   @default("")
  mimeType     String   @default("")
  size         Int      @default(0)
  url          String
  alt          String   @default("")
  category     String   @default("general")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}
